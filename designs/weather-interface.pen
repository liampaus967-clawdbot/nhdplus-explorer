<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Weather Interface - Design Reference</title>
  <style>
    * {
      margin: 0;
      padding: 0;
      box-sizing: border-box;
    }
    
    body {
      font-family: 'Inter', -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif;
      min-height: 100vh;
      display: flex;
      flex-direction: column;
      align-items: center;
      padding: 40px;
      gap: 60px;
      background: linear-gradient(135deg, #1e293b 0%, #0f172a 100%);
    }
    
    h1 {
      color: #f1f5f9;
      font-size: 24px;
      font-weight: 600;
    }
    
    h2 {
      color: #60a5fa;
      font-size: 14px;
      font-weight: 600;
      text-transform: uppercase;
      letter-spacing: 1px;
      margin-bottom: 20px;
    }
    
    .design-section {
      display: flex;
      flex-direction: column;
      align-items: center;
      gap: 20px;
    }
    
    .theme-row {
      display: flex;
      gap: 40px;
      align-items: flex-start;
    }
    
    .theme-section {
      display: flex;
      flex-direction: column;
      align-items: center;
      gap: 12px;
    }
    
    .theme-label {
      font-size: 11px;
      font-weight: 600;
      color: #94a3b8;
      text-transform: uppercase;
      letter-spacing: 0.5px;
    }
    
    .description {
      max-width: 600px;
      text-align: center;
      color: #94a3b8;
      font-size: 13px;
      line-height: 1.6;
      margin-bottom: 20px;
    }
    
    /* ========== CSS VARIABLES ========== */
    :root {
      --bg: #0f172a;
      --bg-secondary: #1e293b;
      --bg-tertiary: #334155;
      --border: #334155;
      --text: #e2e8f0;
      --text-muted: #94a3b8;
      --text-dim: #64748b;
      --accent: #60a5fa;
      --success: #10b981;
      --warning: #f59e0b;
      --danger: #ef4444;
    }
    
    .light {
      --bg: #ffffff;
      --bg-secondary: #f8fafc;
      --bg-tertiary: #e2e8f0;
      --border: #e2e8f0;
      --text: #0f172a;
      --text-muted: #475569;
      --text-dim: #64748b;
      --accent: #2563eb;
    }

    /* ========================================
       SECTION 1: ICON RAIL BUTTON
       ======================================== */
    
    .icon-rail {
      display: flex;
      flex-direction: column;
      gap: 4px;
      padding: 8px;
      background: var(--bg-secondary);
      border-radius: 12px;
      border: 1px solid var(--border);
    }
    
    .rail-btn {
      width: 44px;
      height: 44px;
      display: flex;
      align-items: center;
      justify-content: center;
      border-radius: 10px;
      border: none;
      background: transparent;
      color: var(--text-muted);
      cursor: pointer;
      transition: all 0.15s;
    }
    
    .rail-btn:hover {
      background: var(--bg-tertiary);
      color: var(--text);
    }
    
    .rail-btn.active {
      background: rgba(96, 165, 250, 0.15);
      color: var(--accent);
    }
    
    .rail-btn svg {
      width: 22px;
      height: 22px;
    }
    
    .rail-divider {
      height: 1px;
      background: var(--border);
      margin: 4px 6px;
    }

    /* ========================================
       SECTION 2: WEATHER PANEL - OPTION A
       Slide-out panel with tabs
       ======================================== */
    
    .weather-panel-a {
      width: 320px;
      background: var(--bg-secondary);
      border-radius: 16px;
      border: 1px solid var(--border);
      overflow: hidden;
      box-shadow: 0 8px 32px rgba(0, 0, 0, 0.2);
    }
    
    .panel-header {
      display: flex;
      align-items: center;
      justify-content: space-between;
      padding: 16px 20px;
      border-bottom: 1px solid var(--border);
    }
    
    .panel-title {
      display: flex;
      align-items: center;
      gap: 10px;
      font-size: 15px;
      font-weight: 600;
      color: var(--text);
    }
    
    .panel-title svg {
      width: 20px;
      height: 20px;
      color: var(--accent);
    }
    
    .close-btn {
      width: 32px;
      height: 32px;
      display: flex;
      align-items: center;
      justify-content: center;
      border-radius: 8px;
      border: none;
      background: transparent;
      color: var(--text-muted);
      cursor: pointer;
    }
    
    .close-btn:hover {
      background: var(--bg-tertiary);
    }
    
    .panel-tabs {
      display: flex;
      padding: 0 16px;
      gap: 4px;
      border-bottom: 1px solid var(--border);
    }
    
    .tab {
      padding: 12px 16px;
      font-size: 13px;
      font-weight: 500;
      color: var(--text-muted);
      background: none;
      border: none;
      cursor: pointer;
      position: relative;
    }
    
    .tab.active {
      color: var(--accent);
    }
    
    .tab.active::after {
      content: '';
      position: absolute;
      bottom: 0;
      left: 0;
      right: 0;
      height: 2px;
      background: var(--accent);
      border-radius: 2px 2px 0 0;
    }
    
    .panel-content {
      padding: 16px;
    }
    
    .model-badge {
      display: inline-flex;
      align-items: center;
      gap: 8px;
      padding: 8px 14px;
      background: var(--bg-tertiary);
      border-radius: 20px;
      font-size: 12px;
      font-weight: 500;
      color: var(--text);
      margin-bottom: 16px;
    }
    
    .model-badge .dot {
      width: 8px;
      height: 8px;
      border-radius: 50%;
      background: var(--success);
    }
    
    .model-badge .age {
      color: var(--success);
      font-weight: 600;
    }
    
    .variable-grid {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 8px;
      margin-bottom: 20px;
    }
    
    .variable-card {
      padding: 14px;
      background: var(--bg);
      border: 1px solid var(--border);
      border-radius: 12px;
      cursor: pointer;
      transition: all 0.15s;
    }
    
    .variable-card:hover {
      border-color: var(--accent);
    }
    
    .variable-card.selected {
      background: rgba(96, 165, 250, 0.1);
      border-color: var(--accent);
    }
    
    .variable-icon {
      width: 32px;
      height: 32px;
      display: flex;
      align-items: center;
      justify-content: center;
      background: var(--bg-tertiary);
      border-radius: 8px;
      margin-bottom: 10px;
      font-size: 16px;
    }
    
    .variable-card.selected .variable-icon {
      background: rgba(96, 165, 250, 0.2);
    }
    
    .variable-name {
      font-size: 12px;
      font-weight: 600;
      color: var(--text);
      margin-bottom: 2px;
    }
    
    .variable-unit {
      font-size: 11px;
      color: var(--text-dim);
    }

    /* ========================================
       SECTION 3: WEATHER PANEL - OPTION B  
       Compact card with forecast timeline
       ======================================== */
    
    .weather-panel-b {
      width: 340px;
      background: var(--bg-secondary);
      border-radius: 16px;
      border: 1px solid var(--border);
      overflow: hidden;
      box-shadow: 0 8px 32px rgba(0, 0, 0, 0.2);
    }
    
    .hero-section {
      padding: 20px;
      background: linear-gradient(135deg, rgba(96, 165, 250, 0.15) 0%, rgba(139, 92, 246, 0.1) 100%);
      border-bottom: 1px solid var(--border);
    }
    
    .hero-top {
      display: flex;
      justify-content: space-between;
      align-items: flex-start;
      margin-bottom: 16px;
    }
    
    .hero-label {
      font-size: 11px;
      font-weight: 600;
      text-transform: uppercase;
      letter-spacing: 0.5px;
      color: var(--accent);
    }
    
    .hero-value {
      font-size: 48px;
      font-weight: 700;
      color: var(--text);
      line-height: 1;
    }
    
    .hero-unit {
      font-size: 20px;
      font-weight: 400;
      color: var(--text-muted);
      margin-left: 4px;
    }
    
    .hero-variable {
      font-size: 14px;
      color: var(--text-muted);
      margin-top: 4px;
    }
    
    .live-indicator {
      display: flex;
      align-items: center;
      gap: 6px;
      padding: 6px 12px;
      background: rgba(16, 185, 129, 0.15);
      border-radius: 20px;
      font-size: 11px;
      font-weight: 600;
      color: var(--success);
    }
    
    .live-indicator .pulse {
      width: 8px;
      height: 8px;
      border-radius: 50%;
      background: var(--success);
      animation: pulse 2s infinite;
    }
    
    @keyframes pulse {
      0%, 100% { opacity: 1; transform: scale(1); }
      50% { opacity: 0.5; transform: scale(1.2); }
    }
    
    .forecast-timeline {
      display: flex;
      gap: 4px;
      padding: 16px;
      overflow-x: auto;
    }
    
    .forecast-hour {
      flex-shrink: 0;
      width: 52px;
      padding: 12px 8px;
      background: var(--bg);
      border: 1px solid var(--border);
      border-radius: 12px;
      text-align: center;
      cursor: pointer;
      transition: all 0.15s;
    }
    
    .forecast-hour:hover {
      border-color: var(--accent);
    }
    
    .forecast-hour.active {
      background: var(--accent);
      border-color: var(--accent);
    }
    
    .forecast-hour.active .hour-label,
    .forecast-hour.active .hour-value {
      color: white;
    }
    
    .hour-label {
      font-size: 10px;
      font-weight: 600;
      color: var(--text-dim);
      margin-bottom: 6px;
    }
    
    .hour-value {
      font-size: 14px;
      font-weight: 700;
      color: var(--text);
    }
    
    .layer-list {
      padding: 12px 16px;
      border-top: 1px solid var(--border);
    }
    
    .layer-item {
      display: flex;
      align-items: center;
      justify-content: space-between;
      padding: 10px 0;
    }
    
    .layer-item:not(:last-child) {
      border-bottom: 1px solid var(--border);
    }
    
    .layer-info {
      display: flex;
      align-items: center;
      gap: 10px;
    }
    
    .layer-icon {
      width: 28px;
      height: 28px;
      display: flex;
      align-items: center;
      justify-content: center;
      background: var(--bg-tertiary);
      border-radius: 6px;
      font-size: 14px;
    }
    
    .layer-name {
      font-size: 13px;
      font-weight: 500;
      color: var(--text);
    }
    
    .toggle-switch {
      width: 40px;
      height: 22px;
      background: var(--bg-tertiary);
      border-radius: 11px;
      position: relative;
      cursor: pointer;
      transition: background 0.2s;
    }
    
    .toggle-switch.on {
      background: var(--accent);
    }
    
    .toggle-switch::after {
      content: '';
      position: absolute;
      top: 2px;
      left: 2px;
      width: 18px;
      height: 18px;
      background: white;
      border-radius: 50%;
      transition: transform 0.2s;
    }
    
    .toggle-switch.on::after {
      transform: translateX(18px);
    }

    /* ========================================
       SECTION 4: WEATHER PANEL - OPTION C
       Minimal floating card style
       ======================================== */
    
    .weather-panel-c {
      width: 280px;
      background: var(--bg-secondary);
      border-radius: 20px;
      border: 1px solid var(--border);
      overflow: hidden;
      box-shadow: 0 12px 40px rgba(0, 0, 0, 0.25);
    }
    
    .glass-header {
      padding: 20px;
      background: linear-gradient(180deg, rgba(255,255,255,0.08) 0%, transparent 100%);
    }
    
    .glass-title {
      display: flex;
      align-items: center;
      justify-content: space-between;
    }
    
    .title-text {
      display: flex;
      align-items: center;
      gap: 8px;
      font-size: 14px;
      font-weight: 600;
      color: var(--text);
    }
    
    .title-text svg {
      color: var(--accent);
    }
    
    .status-pill {
      padding: 4px 10px;
      background: rgba(16, 185, 129, 0.15);
      border-radius: 10px;
      font-size: 10px;
      font-weight: 700;
      color: var(--success);
      text-transform: uppercase;
    }
    
    .current-display {
      text-align: center;
      padding: 24px 20px;
    }
    
    .current-icon {
      width: 64px;
      height: 64px;
      margin: 0 auto 12px;
      background: linear-gradient(135deg, var(--accent) 0%, #8b5cf6 100%);
      border-radius: 20px;
      display: flex;
      align-items: center;
      justify-content: center;
      font-size: 28px;
    }
    
    .current-label {
      font-size: 13px;
      color: var(--text-muted);
      margin-bottom: 4px;
    }
    
    .current-value {
      font-size: 36px;
      font-weight: 700;
      color: var(--text);
    }
    
    .quick-layers {
      padding: 16px;
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      gap: 8px;
    }
    
    .quick-layer {
      padding: 12px 8px;
      background: var(--bg);
      border: 1px solid var(--border);
      border-radius: 12px;
      text-align: center;
      cursor: pointer;
      transition: all 0.15s;
    }
    
    .quick-layer:hover {
      border-color: var(--accent);
    }
    
    .quick-layer.active {
      background: rgba(96, 165, 250, 0.1);
      border-color: var(--accent);
    }
    
    .quick-layer-icon {
      font-size: 18px;
      margin-bottom: 4px;
    }
    
    .quick-layer-name {
      font-size: 10px;
      font-weight: 600;
      color: var(--text-muted);
    }
    
    .quick-layer.active .quick-layer-name {
      color: var(--accent);
    }
    
    .opacity-row {
      display: flex;
      align-items: center;
      gap: 12px;
      padding: 12px 16px;
      border-top: 1px solid var(--border);
    }
    
    .opacity-label {
      font-size: 12px;
      font-weight: 500;
      color: var(--text-muted);
      white-space: nowrap;
    }
    
    .opacity-slider {
      flex: 1;
      height: 4px;
      background: var(--bg-tertiary);
      border-radius: 2px;
      position: relative;
    }
    
    .opacity-fill {
      position: absolute;
      left: 0;
      top: 0;
      height: 100%;
      width: 70%;
      background: var(--accent);
      border-radius: 2px;
    }
    
    .opacity-handle {
      position: absolute;
      top: 50%;
      left: 70%;
      width: 14px;
      height: 14px;
      background: white;
      border: 2px solid var(--accent);
      border-radius: 50%;
      transform: translate(-50%, -50%);
      cursor: pointer;
    }
    
    .opacity-value {
      font-size: 12px;
      font-weight: 600;
      color: var(--accent);
      min-width: 32px;
      text-align: right;
    }

    /* ========================================
       SECTION 5: COLOR LEGEND
       ======================================== */
    
    .color-legend {
      padding: 16px;
      background: var(--bg);
      border-top: 1px solid var(--border);
    }
    
    .legend-title {
      font-size: 11px;
      font-weight: 600;
      color: var(--text-dim);
      text-transform: uppercase;
      letter-spacing: 0.5px;
      margin-bottom: 10px;
    }
    
    .legend-bar {
      height: 12px;
      border-radius: 6px;
      background: linear-gradient(90deg, 
        #1a0066 0%, 
        #4d0099 10%, 
        #0000ff 20%, 
        #00ccff 30%, 
        #00ff00 40%, 
        #99ff00 50%, 
        #ffff00 60%, 
        #ffcc00 70%, 
        #ff6600 85%, 
        #ff0000 100%
      );
      margin-bottom: 6px;
    }
    
    .legend-labels {
      display: flex;
      justify-content: space-between;
      font-size: 10px;
      color: var(--text-dim);
    }

    /* ========================================
       ANIMATION CONTROLS
       ======================================== */
    
    .animation-controls {
      display: flex;
      align-items: center;
      justify-content: center;
      gap: 8px;
      padding: 12px;
      background: var(--bg);
      border-top: 1px solid var(--border);
    }
    
    .anim-btn {
      width: 36px;
      height: 36px;
      display: flex;
      align-items: center;
      justify-content: center;
      border-radius: 50%;
      border: none;
      background: var(--bg-tertiary);
      color: var(--text-muted);
      cursor: pointer;
      transition: all 0.15s;
    }
    
    .anim-btn:hover {
      background: var(--accent);
      color: white;
    }
    
    .anim-btn.play {
      width: 44px;
      height: 44px;
      background: var(--accent);
      color: white;
    }
    
    .time-display {
      min-width: 100px;
      text-align: center;
      font-size: 12px;
      font-weight: 600;
      color: var(--text);
    }
    
    .time-small {
      font-size: 10px;
      color: var(--text-dim);
      font-weight: 400;
    }
    
  </style>
</head>
<body>
  
  <h1>Weather Interface Design Options</h1>
  
  <!-- ========================================
       SECTION 1: ICON RAIL BUTTON
       ======================================== -->
  
  <div class="design-section">
    <h2>1. Icon Rail Button (Left Map Controls)</h2>
    <p class="description">
      The weather button lives in the icon rail on the left side of the map,
      below the basemap selector. When clicked, it opens the weather panel.
    </p>
    
    <div class="theme-row">
      <div class="theme-section">
        <span class="theme-label">Dark Theme</span>
        <div class="icon-rail">
          <button class="rail-btn">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <circle cx="12" cy="12" r="3"/>
              <path d="M12 3v2m0 14v2M3 12h2m14 0h2m-4.2-5.8 1.4-1.4M6.3 17.7l1.4-1.4m0-8.6-1.4-1.4m11.4 11.4-1.4-1.4"/>
            </svg>
          </button>
          <button class="rail-btn">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <rect x="3" y="3" width="18" height="18" rx="2"/>
              <path d="M3 9h18M9 21V9"/>
            </svg>
          </button>
          <div class="rail-divider"></div>
          <button class="rail-btn active" title="Weather">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <path d="M17.5 19a4.5 4.5 0 1 0 0-9h-.5A7 7 0 1 0 5 15"/>
              <path d="M9.5 19h8"/>
            </svg>
          </button>
        </div>
      </div>
      
      <div class="theme-section light">
        <span class="theme-label">Light Theme</span>
        <div class="icon-rail">
          <button class="rail-btn">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <circle cx="12" cy="12" r="3"/>
              <path d="M12 3v2m0 14v2M3 12h2m14 0h2m-4.2-5.8 1.4-1.4M6.3 17.7l1.4-1.4m0-8.6-1.4-1.4m11.4 11.4-1.4-1.4"/>
            </svg>
          </button>
          <button class="rail-btn">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <rect x="3" y="3" width="18" height="18" rx="2"/>
              <path d="M3 9h18M9 21V9"/>
            </svg>
          </button>
          <div class="rail-divider"></div>
          <button class="rail-btn active" title="Weather">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <path d="M17.5 19a4.5 4.5 0 1 0 0-9h-.5A7 7 0 1 0 5 15"/>
              <path d="M9.5 19h8"/>
            </svg>
          </button>
        </div>
      </div>
    </div>
  </div>

  <!-- ========================================
       SECTION 2: OPTION A - Tabbed Panel
       ======================================== -->
  
  <div class="design-section">
    <h2>2. Option A: Tabbed Panel with Variable Cards</h2>
    <p class="description">
      Full-featured panel with tabs for Layers, Forecast, and Settings.
      Variables displayed as interactive cards with icons.
    </p>
    
    <div class="theme-row">
      <div class="theme-section">
        <span class="theme-label">Dark Theme</span>
        <div class="weather-panel-a">
          <div class="panel-header">
            <div class="panel-title">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <path d="M17.5 19a4.5 4.5 0 1 0 0-9h-.5A7 7 0 1 0 5 15"/>
                <path d="M9.5 19h8"/>
              </svg>
              Weather
            </div>
            <button class="close-btn">✕</button>
          </div>
          <div class="panel-tabs">
            <button class="tab active">Layers</button>
            <button class="tab">Forecast</button>
            <button class="tab">Settings</button>
          </div>
          <div class="panel-content">
            <div class="model-badge">
              <span class="dot"></span>
              HRRR 09Z
              <span class="age">2h ago</span>
            </div>
            <div class="variable-grid">
              <div class="variable-card selected">
                <div class="variable-icon">🌡️</div>
                <div class="variable-name">Temperature</div>
                <div class="variable-unit">°C</div>
              </div>
              <div class="variable-card">
                <div class="variable-icon">💨</div>
                <div class="variable-name">Wind Gust</div>
                <div class="variable-unit">mph</div>
              </div>
              <div class="variable-card">
                <div class="variable-icon">☁️</div>
                <div class="variable-name">Cloud Cover</div>
                <div class="variable-unit">%</div>
              </div>
              <div class="variable-card">
                <div class="variable-icon">🌧️</div>
                <div class="variable-name">Precipitation</div>
                <div class="variable-unit">in</div>
              </div>
              <div class="variable-card">
                <div class="variable-icon">❄️</div>
                <div class="variable-name">Snow</div>
                <div class="variable-unit">in</div>
              </div>
              <div class="variable-card">
                <div class="variable-icon">🔥</div>
                <div class="variable-name">Smoke</div>
                <div class="variable-unit">μg/m³</div>
              </div>
            </div>
          </div>
          <div class="color-legend">
            <div class="legend-title">Temperature (2m)</div>
            <div class="legend-bar"></div>
            <div class="legend-labels">
              <span>-40°C</span>
              <span>50°C</span>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>

  <!-- ========================================
       SECTION 3: OPTION B - Timeline Style
       ======================================== -->
  
  <div class="design-section">
    <h2>3. Option B: Hero Display with Timeline</h2>
    <p class="description">
      Large value display at top with horizontal scrolling forecast timeline.
      Great for quickly scrubbing through forecast hours.
    </p>
    
    <div class="theme-row">
      <div class="theme-section">
        <span class="theme-label">Dark Theme</span>
        <div class="weather-panel-b">
          <div class="hero-section">
            <div class="hero-top">
              <div>
                <div class="hero-label">Temperature at 2m</div>
                <div class="hero-value">
                  24<span class="hero-unit">°C</span>
                </div>
                <div class="hero-variable">Current conditions</div>
              </div>
              <div class="live-indicator">
                <div class="pulse"></div>
                LIVE
              </div>
            </div>
          </div>
          <div class="forecast-timeline">
            <div class="forecast-hour active">
              <div class="hour-label">NOW</div>
              <div class="hour-value">24°</div>
            </div>
            <div class="forecast-hour">
              <div class="hour-label">+1h</div>
              <div class="hour-value">23°</div>
            </div>
            <div class="forecast-hour">
              <div class="hour-label">+2h</div>
              <div class="hour-value">22°</div>
            </div>
            <div class="forecast-hour">
              <div class="hour-label">+3h</div>
              <div class="hour-value">20°</div>
            </div>
            <div class="forecast-hour">
              <div class="hour-label">+4h</div>
              <div class="hour-value">18°</div>
            </div>
            <div class="forecast-hour">
              <div class="hour-label">+5h</div>
              <div class="hour-value">16°</div>
            </div>
          </div>
          <div class="layer-list">
            <div class="layer-item">
              <div class="layer-info">
                <div class="layer-icon">🌡️</div>
                <div class="layer-name">Temperature</div>
              </div>
              <div class="toggle-switch on"></div>
            </div>
            <div class="layer-item">
              <div class="layer-info">
                <div class="layer-icon">💨</div>
                <div class="layer-name">Wind Gust</div>
              </div>
              <div class="toggle-switch"></div>
            </div>
            <div class="layer-item">
              <div class="layer-info">
                <div class="layer-icon">☁️</div>
                <div class="layer-name">Cloud Cover</div>
              </div>
              <div class="toggle-switch"></div>
            </div>
          </div>
          <div class="animation-controls">
            <button class="anim-btn">⏮</button>
            <button class="anim-btn play">▶</button>
            <button class="anim-btn">⏭</button>
            <div class="time-display">
              <div>Feb 24, 2026</div>
              <div class="time-small">09:00 UTC</div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>

  <!-- ========================================
       SECTION 4: OPTION C - Minimal Card
       ======================================== -->
  
  <div class="design-section">
    <h2>4. Option C: Minimal Floating Card</h2>
    <p class="description">
      Clean, compact design with quick-toggle layer icons.
      Focuses on simplicity and fast interactions.
    </p>
    
    <div class="theme-row">
      <div class="theme-section">
        <span class="theme-label">Dark Theme</span>
        <div class="weather-panel-c">
          <div class="glass-header">
            <div class="glass-title">
              <div class="title-text">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                  <path d="M17.5 19a4.5 4.5 0 1 0 0-9h-.5A7 7 0 1 0 5 15"/>
                  <path d="M9.5 19h8"/>
                </svg>
                Weather
              </div>
              <span class="status-pill">Live</span>
            </div>
          </div>
          <div class="current-display">
            <div class="current-icon">🌡️</div>
            <div class="current-label">Temperature at 2m</div>
            <div class="current-value">24°C</div>
          </div>
          <div class="quick-layers">
            <div class="quick-layer active">
              <div class="quick-layer-icon">🌡️</div>
              <div class="quick-layer-name">Temp</div>
            </div>
            <div class="quick-layer">
              <div class="quick-layer-icon">💨</div>
              <div class="quick-layer-name">Wind</div>
            </div>
            <div class="quick-layer">
              <div class="quick-layer-icon">☁️</div>
              <div class="quick-layer-name">Clouds</div>
            </div>
            <div class="quick-layer">
              <div class="quick-layer-icon">🌧️</div>
              <div class="quick-layer-name">Rain</div>
            </div>
            <div class="quick-layer">
              <div class="quick-layer-icon">❄️</div>
              <div class="quick-layer-name">Snow</div>
            </div>
            <div class="quick-layer">
              <div class="quick-layer-icon">🔥</div>
              <div class="quick-layer-name">Smoke</div>
            </div>
          </div>
          <div class="opacity-row">
            <span class="opacity-label">Opacity</span>
            <div class="opacity-slider">
              <div class="opacity-fill"></div>
              <div class="opacity-handle"></div>
            </div>
            <span class="opacity-value">70%</span>
          </div>
          <div class="color-legend">
            <div class="legend-title">Temperature</div>
            <div class="legend-bar"></div>
            <div class="legend-labels">
              <span>-40°C</span>
              <span>50°C</span>
            </div>
          </div>
        </div>
      </div>
      
      <div class="theme-section light">
        <span class="theme-label">Light Theme</span>
        <div class="weather-panel-c light">
          <div class="glass-header">
            <div class="glass-title">
              <div class="title-text">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                  <path d="M17.5 19a4.5 4.5 0 1 0 0-9h-.5A7 7 0 1 0 5 15"/>
                  <path d="M9.5 19h8"/>
                </svg>
                Weather
              </div>
              <span class="status-pill">Live</span>
            </div>
          </div>
          <div class="current-display">
            <div class="current-icon">🌡️</div>
            <div class="current-label">Temperature at 2m</div>
            <div class="current-value">24°C</div>
          </div>
          <div class="quick-layers">
            <div class="quick-layer active">
              <div class="quick-layer-icon">🌡️</div>
              <div class="quick-layer-name">Temp</div>
            </div>
            <div class="quick-layer">
              <div class="quick-layer-icon">💨</div>
              <div class="quick-layer-name">Wind</div>
            </div>
            <div class="quick-layer">
              <div class="quick-layer-icon">☁️</div>
              <div class="quick-layer-name">Clouds</div>
            </div>
            <div class="quick-layer">
              <div class="quick-layer-icon">🌧️</div>
              <div class="quick-layer-name">Rain</div>
            </div>
            <div class="quick-layer">
              <div class="quick-layer-icon">❄️</div>
              <div class="quick-layer-name">Snow</div>
            </div>
            <div class="quick-layer">
              <div class="quick-layer-icon">🔥</div>
              <div class="quick-layer-name">Smoke</div>
            </div>
          </div>
          <div class="opacity-row">
            <span class="opacity-label">Opacity</span>
            <div class="opacity-slider">
              <div class="opacity-fill"></div>
              <div class="opacity-handle"></div>
            </div>
            <span class="opacity-value">70%</span>
          </div>
          <div class="color-legend">
            <div class="legend-title">Temperature</div>
            <div class="legend-bar"></div>
            <div class="legend-labels">
              <span>-40°C</span>
              <span>50°C</span>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>

</body>
</html>
